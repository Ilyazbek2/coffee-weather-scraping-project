import pandas as pd
import matplotlib.pyplot as plt

data = {
    "День недели": [
        "Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday",
        "Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday",
        "Monday","Tuesday"
    ],
    "Количество Продаж": [
        197,58,99,196,132,105,50,
        190,100,127,58,88,66,175,
        140,55
    ],
    "Тип Кофе": [
        "Латте","Эспрессо","Эспрессо","Эспрессо","Капучино","Латте","Латте",
        "Латте","Латте","Латте","Капучино","Латте","Эспрессо","Эспрессо",
        "Латте","Латте"
    ],
    "Цена за Чашку": [
        131,143,192,142,117,113,100,
        185,132,175,200,190,130,189,
        132,132
    ],
    "Выходной": [
        "Нет","Нет","Нет","Да","Нет","Да","Да",
        "Нет","Нет","Нет","Да","Да","Нет","Нет",
        "Нет","Нет"
    ]
}

df = pd.DataFrame(data)
df.head()

plt.figure(figsize=(8, 5))
df.boxplot(column="Цена за Чашку", by="Тип Кофе", grid=True)

plt.title("Распределение цен по типам кофе")
plt.suptitle("")
plt.xlabel("Тип кофе")
plt.ylabel("Цена (руб.)")
plt.show()

grouped = df.groupby("Выходной")["Количество Продаж"].sum()

plt.figure(figsize=(7, 5))
plt.bar(["Будни", "Выходные"],
        [grouped["Нет"], grouped["Да"]],
        color=["teal", "orange"])

plt.title("Продажи: будни vs выходные")
plt.ylabel("Количество продаж")
plt.show()

grouped

group_day = df.groupby("День недели")["Количество Продаж"].sum()

plt.figure(figsize=(8, 5))
plt.bar(group_day.index, group_day.values, color="purple")

plt.title("Продажи по дням недели")
plt.ylabel("Количество продаж")
plt.show()
